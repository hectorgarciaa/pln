# Copia este fichero a p4/.env si quieres sobreescribir la configuración
# por defecto de la práctica 4.

QUIJOTE_PREPROCESSING__SPACY_MODEL=es_core_news_lg
QUIJOTE_CHUNKING__TARGET_WORDS=180
QUIJOTE_CHUNKING__OVERLAP_WORDS=45
QUIJOTE_SEARCH__TOP_K=8
QUIJOTE_SEARCH__SURFACE_WEIGHT=0.35
QUIJOTE_SEARCH__LEMMA_WEIGHT=0.65
QUIJOTE_SEMANTIC__BATCH_SIZE=32
QUIJOTE_SEMANTIC__INDEX_VERSION=2
QUIJOTE_SEMANTIC__TITLE_WEIGHT=0.35
QUIJOTE_SEMANTIC__BODY_WEIGHT=0.65
QUIJOTE_SEMANTIC__ORIGINAL_QUERY_WEIGHT=0.65
QUIJOTE_SEMANTIC__NORMALIZED_QUERY_WEIGHT=0.35
QUIJOTE_SEMANTIC__LEXICAL_BONUS_WEIGHT=0.15
QUIJOTE_SEMANTIC__RERANK_POOL_SIZE=40
QUIJOTE_OLLAMA__HOST=http://127.0.0.1:11434
QUIJOTE_OLLAMA__TIMEOUT_SECONDS=30
QUIJOTE_RAG__ENABLED=true
QUIJOTE_RAG__GENERATION_MODEL=qwen3:8b
QUIJOTE_RAG__TEMPERATURE=0.2
QUIJOTE_RAG__NUM_PREDICT=384
QUIJOTE_RAG__HYBRID_TOP_K=5
QUIJOTE_RAG__MAX_SOURCES=4
QUIJOTE_RAG__MAX_CONTEXT_CHARS=6000
QUIJOTE_RAG__MAX_SOURCE_CHARS=1400
QUIJOTE_RAG__CLASSICAL_WEIGHT=0.8
QUIJOTE_RAG__SEMANTIC_WEIGHT=0.2
QUIJOTE_RAG__RRF_K=10
QUIJOTE_RAG__MIN_SCORE_RATIO=0.96
QUIJOTE_RAG__SEMANTIC_ONLY_ZERO_OVERLAP_PENALTY=0.3
