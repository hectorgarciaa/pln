# --- Caché y ejecución de Python ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.python-version
.ruff_cache/
.codex
# --- Build / distribución ---
dist/
build/
*.egg-info/

# --- Entornos Virtuales ---
# En tu imagen se ve la carpeta .venv, es fundamental ignorarla
.venv/
.uv-cache/
venv/
env/

# --- Gestión de dependencias (uv / pip) ---
# Los `uv.lock` por práctica sí se versionan para fijar entornos reproducibles.

# --- Logs y Datos temporales ---
p1/app/logs/
*.log
estado_butler.json
p4/artifacts/*
!p4/artifacts/.gitkeep
p4/logs/*
!p4/logs/.gitkeep

p5/artifacts/*
!p5/artifacts/best/

# --- Estado de runtime del agente ---
p1/app/state/*.json

# --- Variables de entorno locales ---
.env
p4/.env
# --- Archivos de configuración de IDE ---
.vscode/
.idea/

# --- Archivos del sistema ---
.DS_Store
Thumbs.db
