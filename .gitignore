# aunque en proyectos finales se suele subir. Por ahora lo dejamos fuera si es desarrollo local.
# uv.lock 

# --- Logs y Datos temporales ---
app/logs/
*.log
estado_butler.json

# --- Estado de runtime del agente ---
app/state/*.json

# --- Variables de entorno locales ---
.env
# --- Archivos de configuración de IDE ---
.vscode/
.idea/

