# --- Caché y ejecución de Python ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.python-version
.ruff_cache/

# --- Build / distribución ---
dist/
build/
*.egg-info/

# --- Entornos Virtuales ---
# En tu imagen se ve la carpeta .venv, es fundamental ignorarla
.venv/
venv/
env/

# --- Gestión de dependencias (uv / pip) ---
