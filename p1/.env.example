# ── Configuración del Bot Negociador (PLN — Grupo 02) ───────────────────
# Copiar este archivo como p1/.env y ajustar los valores.
# Las variables de entorno del sistema SIEMPRE tienen prioridad sobre .env.

# URL del servidor Butler (obligatoria en laboratorios)
FDI_PLN__BUTLER_ADDRESS=127.0.0.1:7719

# URL de Ollama (inferencia local)
FDI_PLN__OLLAMA_URL=http://127.0.0.1:11434

# Modelo LLM a usar por defecto
FDI_PLN__MODELO=qwen3:8b
